            "yaw": 0, "pitch": 0
          }
        },
        {
          "type": "FADE_IN",
          "delay": 20,
          "parameters": {
            "duration": 20
          }
        },
        {
          "type": "SHOW_TITLE",
          "delay": 25,
          "parameters": {
            "text": "§b§lОбучение",
